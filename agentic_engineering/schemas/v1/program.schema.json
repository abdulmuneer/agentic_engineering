{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.engineering/schemas/v1/program.schema.json",
  "title": "Agentic Engineering Program",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "framework_version", "program"],
  "properties": {
    "schema_version": {"const": 1},
    "framework_version": {"const": "0.1.0"},
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "accountable_human", "source_roots", "governance_root", "current_gate", "framework_lock", "source_of_truth", "profile", "capabilities", "actors"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "framework_preset": {"type": "string", "minLength": 1},
        "accountable_human": {"$ref": "#/$defs/id"},
        "source_roots": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "governance_root": {"type": "string", "minLength": 1},
        "current_gate": {"type": "string", "minLength": 1},
        "framework_lock": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "catalog_sha256", "schemas_sha256", "behavior_sha256"],
          "properties": {
            "version": {"type": "string", "minLength": 1},
            "catalog_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
            "schemas_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
            "behavior_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
          }
        },
        "source_of_truth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "declared_version", "sha256"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "declared_version": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
            "history": {
              "type": "array",
              "items": {"$ref": "#/$defs/sourceHistory"}
            },
            "updated_by": {"$ref": "#/$defs/id"},
            "update_decision_ref": {"$ref": "#/$defs/id"},
            "updated_at": {"type": "string", "format": "date-time"}
          }
        },
        "profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["product_type", "lifecycle_phase", "surfaces", "deployment_targets", "data_classes", "risk_domains"],
          "properties": {
            "product_type": {"type": "string", "minLength": 1},
            "lifecycle_phase": {"enum": ["discovery", "validation", "delivery", "production", "maintenance", "sunset"]},
            "surfaces": {"$ref": "#/$defs/stringSet"},
            "deployment_targets": {"$ref": "#/$defs/stringSet"},
            "data_classes": {"$ref": "#/$defs/stringSet"},
            "risk_domains": {"$ref": "#/$defs/stringSet"}
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/capability"}
        },
        "actors": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/actor"}
        },
        "workflow_defaults": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        },
        "risk_defaults": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "baseline": {"enum": ["low", "medium", "high", "critical"]}
          }
        },
        "tailoring": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "questions"],
          "properties": {
            "status": {"enum": ["pending", "confirmed"]},
            "questions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "answers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["question", "answer"],
                "properties": {
                  "question": {"type": "string", "minLength": 1},
                  "answer": {"type": "string", "minLength": 1}
                }
              }
            },
            "confirmed_by": {"$ref": "#/$defs/id"},
            "confirmed_at": {"type": "string", "format": "date-time"}
          },
          "allOf": [
            {
              "if": {"properties": {"status": {"const": "confirmed"}}, "required": ["status"]},
              "then": {"required": ["answers", "confirmed_by", "confirmed_at"]}
            }
          ]
        },
        "policy_refs": {"$ref": "#/$defs/stringSet"}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$"},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "sourceHistory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "declared_version", "sha256", "superseded_by", "superseded_at", "decision_ref"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "declared_version": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "superseded_by": {"$ref": "#/$defs/id"},
        "superseded_at": {"type": "string", "format": "date-time"},
        "decision_ref": {"$ref": "#/$defs/id"}
      }
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "expires_at", "compensating_controls", "decision_ref"],
      "properties": {
        "owner": {"$ref": "#/$defs/id"},
        "expires_at": {"type": "string", "format": "date-time"},
        "compensating_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "decision_ref": {"$ref": "#/$defs/id"}
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "disposition"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "disposition": {"enum": ["active", "not_applicable", "waived"]},
        "owner": {"$ref": "#/$defs/id"},
        "executors": {"$ref": "#/$defs/stringSet"},
        "reviewers": {"$ref": "#/$defs/stringSet"},
        "rationale": {"type": "string", "minLength": 1},
        "reconsider_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "waiver": {"$ref": "#/$defs/waiver"}
      },
      "allOf": [
        {"if": {"properties": {"disposition": {"const": "active"}}, "required": ["disposition"]}, "then": {"required": ["owner"]}},
        {"if": {"properties": {"disposition": {"const": "not_applicable"}}, "required": ["disposition"]}, "then": {"required": ["rationale", "reconsider_when"]}},
        {"if": {"properties": {"disposition": {"const": "waived"}}, "required": ["disposition"]}, "then": {"required": ["rationale", "waiver"]}}
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "capabilities", "permission_ceiling"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["human", "agent", "automation"]},
        "name": {"type": "string", "minLength": 1},
        "capabilities": {"$ref": "#/$defs/stringSet"},
        "permission_ceiling": {"enum": ["read_only", "local_write", "external_read", "external_write", "sensitive", "production"]},
        "specialist_domains": {"$ref": "#/$defs/stringSet"}
      }
    }
  }
}
