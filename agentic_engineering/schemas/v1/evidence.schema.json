{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.engineering/schemas/v1/evidence.schema.json",
  "title": "Agentic Engineering Evidence Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "framework_version", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "framework_version": {"const": "0.1.0"},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "work_item_ref", "packet_ref", "kind", "subject", "producer", "method", "result", "observed_at", "artifacts", "claims_authorized", "claims_forbidden"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "work_item_ref": {"$ref": "#/$defs/id"},
        "acceptance_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "kind": {"enum": ["deterministic_test", "integration_test", "end_to_end_test", "regression_test", "security_test", "static_analysis", "manual_observation", "user_research", "experiment_result", "benchmark", "review", "approval", "deployment_receipt", "monitoring_observation", "document"]},
        "subject": {"$ref": "#/$defs/subject"},
        "producer": {"$ref": "#/$defs/producer"},
        "method": {"$ref": "#/$defs/method"},
        "result": {"enum": ["pass", "fail", "inconclusive", "not_run"]},
        "observed_at": {"type": "string", "format": "date-time"},
        "artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
        "claims_authorized": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "claims_forbidden": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "guard_authorizations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "approval_ref": {"$ref": "#/$defs/id"},
        "authorization_ref": {"$ref": "#/$defs/id"},
        "packet_ref": {"$ref": "#/$defs/id"},
        "action_scope": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "owner": {"$ref": "#/$defs/id"},
        "risk_acceptance_ref": {"$ref": "#/$defs/id"}
      },
      "allOf": [
        {"if": {"properties": {"result": {"enum": ["not_run", "inconclusive"]}}, "required": ["result"]}, "then": {"required": ["rationale", "owner", "risk_acceptance_ref"]}},
        {"if": {"properties": {"kind": {"enum": ["approval", "deployment_receipt"]}}, "required": ["kind"]}, "then": {"required": ["authorization_ref", "packet_ref", "action_scope"]}}
      ]
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$"},
    "digest": {"type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$"},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "pattern": "^[A-Fa-f0-9]{7,64}$"},
        "artifact_digest": {"$ref": "#/$defs/digest"},
        "release_ref": {"$ref": "#/$defs/id"}
      },
      "anyOf": [{"required": ["ref"]}, {"required": ["commit"]}, {"required": ["artifact_digest"]}, {"required": ["release_ref"]}]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "run_id", "type"],
      "properties": {
        "actor": {"$ref": "#/$defs/id"},
        "run_id": {"type": "string", "minLength": 1},
        "type": {"enum": ["human", "agent", "automation"]},
        "context_manifest_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "environment": {"type": "string", "minLength": 1}
      },
      "anyOf": [{"required": ["command"]}, {"required": ["description"]}]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "sha256"],
      "properties": {
        "uri": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    }
  }
}
