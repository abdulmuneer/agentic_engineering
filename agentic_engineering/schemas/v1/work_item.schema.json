{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic.engineering/schemas/v1/work_item.schema.json",
  "title": "Agentic Engineering Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "framework_version", "work_item"],
  "properties": {
    "schema_version": {"const": 1},
    "framework_version": {"const": "0.1.0"},
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "type", "workflow", "state", "source_refs", "source_revision", "objective", "accountable_human", "required_capabilities", "change", "risk", "route", "acceptance", "evidence_plan", "permission_classes"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "title": {"type": "string", "minLength": 1},
        "type": {"enum": ["discovery", "feature", "enhancement", "bug", "defect", "research", "incident", "operations", "release", "documentation", "technical_debt"]},
        "workflow": {"enum": ["discovery", "research_spike", "feature", "bug_fix", "incident", "release"]},
        "state": {"$ref": "#/$defs/state"},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "source_revision": {"type": "string", "minLength": 1},
        "objective": {"type": "string", "minLength": 1},
        "accountable_human": {"$ref": "#/$defs/id"},
        "required_capabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "change": {"$ref": "#/$defs/change"},
        "risk": {"$ref": "#/$defs/risk"},
        "route": {"enum": ["discovery", "research_spike", "feature", "bug_fix", "incident", "release"]},
        "acceptance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/acceptance"}},
        "evidence_plan": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidencePlan"}},
        "permission_classes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/permission"}},
        "dependency_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "decision_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "work_packet_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "discovery": {"$ref": "#/$defs/discovery"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"workflow": {"const": "discovery"}},
            "required": ["workflow"]
          },
          "then": {
            "required": ["discovery"],
            "properties": {
              "type": {"const": "discovery"},
              "route": {"const": "discovery"}
            }
          },
          "else": {"not": {"required": ["discovery"]}}
        },
        {
          "if": {
            "properties": {"type": {"const": "discovery"}},
            "required": ["type"]
          },
          "then": {
            "properties": {
              "workflow": {"const": "discovery"},
              "route": {"const": "discovery"}
            }
          }
        },
        {
          "if": {
            "properties": {
              "workflow": {"const": "discovery"},
              "state": {
                "properties": {
                  "current": {"enum": ["committed", "narrowed", "killed", "parked"]}
                },
                "required": ["current"]
              }
            },
            "required": ["workflow", "state"]
          },
          "then": {
            "properties": {
              "discovery": {
                "properties": {
                  "decision": {
                    "properties": {"status": {"const": "decided"}},
                    "required": ["disposition"]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "workflow": {"const": "discovery"},
              "state": {"properties": {"current": {"const": "committed"}}, "required": ["current"]}
            },
            "required": ["workflow", "state"]
          },
          "then": {
            "properties": {
              "discovery": {"properties": {"decision": {"properties": {"disposition": {"const": "commit"}}}}}
            }
          }
        },
        {
          "if": {
            "properties": {
              "workflow": {"const": "discovery"},
              "state": {"properties": {"current": {"const": "narrowed"}}, "required": ["current"]}
            },
            "required": ["workflow", "state"]
          },
          "then": {
            "properties": {
              "discovery": {"properties": {"decision": {"properties": {"disposition": {"const": "narrow"}}}}}
            }
          }
        },
        {
          "if": {
            "properties": {
              "workflow": {"const": "discovery"},
              "state": {"properties": {"current": {"const": "killed"}}, "required": ["current"]}
            },
            "required": ["workflow", "state"]
          },
          "then": {
            "properties": {
              "discovery": {"properties": {"decision": {"properties": {"disposition": {"const": "kill"}}}}}
            }
          }
        },
        {
          "if": {
            "properties": {
              "workflow": {"const": "discovery"},
              "state": {"properties": {"current": {"const": "parked"}}, "required": ["current"]}
            },
            "required": ["workflow", "state"]
          },
          "then": {
            "properties": {
              "discovery": {"properties": {"decision": {"properties": {"disposition": {"const": "park"}}}}}
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$"},
    "permission": {"enum": ["read_only", "local_write", "external_read", "external_write", "sensitive", "production"]},
    "tier": {"enum": ["low", "medium", "high", "critical"]},
    "assurance": {"enum": ["A0", "A1", "A2", "A3"]},
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "event", "from", "to", "at", "actor"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 1},
        "event": {"type": "string", "minLength": 1},
        "from": {"type": ["string", "null"]},
        "to": {"type": "string", "minLength": 1},
        "at": {"type": "string", "format": "date-time"},
        "actor": {"$ref": "#/$defs/id"},
        "guard_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "confirmed_guard_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "approval_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
        "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "history"],
      "properties": {
        "current": {"type": "string", "minLength": 1},
        "history": {"type": "array", "items": {"$ref": "#/$defs/transition"}}
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaces", "production_affecting", "authentication", "authorization", "sensitive_data", "safety_impact", "regulated_impact", "destructive_migration", "external_write", "reversibility", "blast_radius"],
      "properties": {
        "surfaces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "changed_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "production_affecting": {"$ref": "#/$defs/assessedBoolean"},
        "authentication": {"$ref": "#/$defs/assessedBoolean"},
        "authorization": {"$ref": "#/$defs/assessedBoolean"},
        "sensitive_data": {"$ref": "#/$defs/assessedBoolean"},
        "safety_impact": {"enum": ["unknown", "none", "limited", "severe"]},
        "regulated_impact": {"$ref": "#/$defs/assessedBoolean"},
        "destructive_migration": {"$ref": "#/$defs/assessedBoolean"},
        "external_write": {"$ref": "#/$defs/assessedBoolean"},
        "reversibility": {"enum": ["unknown", "easy", "moderate", "difficult", "irreversible"]},
        "blast_radius": {"enum": ["unknown", "local", "component", "multi_component", "customer_segment", "systemic"]}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effective_tier", "assurance_level", "rule_refs"],
      "properties": {
        "declared_tier": {"$ref": "#/$defs/tier"},
        "effective_tier": {"$ref": "#/$defs/tier"},
        "assurance_level": {"$ref": "#/$defs/assurance"},
        "rule_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "waiver_ref": {"$ref": "#/$defs/id"}
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "evidencePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance_ref", "kinds", "environment", "minimum_assurance"],
      "properties": {
        "acceptance_ref": {"$ref": "#/$defs/id"},
        "kinds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "environment": {"type": "string", "minLength": 1},
        "minimum_assurance": {"$ref": "#/$defs/assurance"}
      }
    },
    "assessedBoolean": {"oneOf": [{"type": "boolean"}, {"const": "unknown"}]},
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem", "actor", "hypothesis", "falsification", "experiment", "decision"],
      "properties": {
        "problem": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement"],
          "properties": {
            "statement": {"type": "string", "minLength": 1},
            "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
          }
        },
        "actor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "description"],
          "properties": {
            "id": {"$ref": "#/$defs/id"},
            "description": {"type": "string", "minLength": 1},
            "context": {"type": "string", "minLength": 1}
          }
        },
        "hypothesis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "expected_outcome"],
          "properties": {
            "statement": {"type": "string", "minLength": 1},
            "expected_outcome": {"type": "string", "minLength": 1},
            "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}}
          }
        },
        "falsification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["criterion", "evaluation_method"],
          "properties": {
            "criterion": {"type": "string", "minLength": 1},
            "metric": {"type": "string", "minLength": 1},
            "threshold": {"type": "string", "minLength": 1},
            "evaluation_method": {"type": "string", "minLength": 1}
          }
        },
        "experiment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "method", "owner", "status", "evidence_refs", "unknowns"],
          "properties": {
            "id": {"$ref": "#/$defs/id"},
            "method": {"type": "string", "minLength": 1},
            "owner": {"$ref": "#/$defs/id"},
            "status": {"enum": ["planned", "running", "completed", "stopped"]},
            "timebox": {"type": "string", "minLength": 1},
            "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
            "unknowns": {"type": "array", "items": {"type": "string", "minLength": 1}}
          }
        },
        "decision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {"enum": ["pending", "decided"]},
            "disposition": {"enum": ["commit", "narrow", "kill", "park"]},
            "rationale": {"type": "string", "minLength": 1},
            "decided_at": {"type": "string", "format": "date-time"},
            "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
            "outcome_measures": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "successor_hypothesis_ref": {"$ref": "#/$defs/id"},
            "revisit_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          },
          "allOf": [
            {
              "if": {"properties": {"status": {"const": "decided"}}, "required": ["status"]},
              "then": {"required": ["disposition", "rationale", "decided_at", "evidence_refs"]}
            },
            {
              "if": {"properties": {"status": {"const": "pending"}}, "required": ["status"]},
              "then": {"not": {"required": ["disposition"]}}
            },
            {
              "if": {"properties": {"disposition": {"const": "commit"}}, "required": ["disposition"]},
              "then": {"required": ["outcome_measures"]}
            },
            {
              "if": {"properties": {"disposition": {"const": "narrow"}}, "required": ["disposition"]},
              "then": {"required": ["successor_hypothesis_ref"]}
            },
            {
              "if": {"properties": {"disposition": {"const": "park"}}, "required": ["disposition"]},
              "then": {"required": ["revisit_when"]}
            }
          ]
        }
      }
    }
  }
}
